{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "",
	"main": "src/index.ts",
	"compatibility_date": "2026-04-21",
	"compatibility_flags": ["nodejs_compat", "no_nodejs_compat_v2", "enable_request_signal", "request_signal_passthrough"],
	"workers_dev": false,
	"preview_urls": false,
	"minify": true,
	"keep_names": false,
	"upload_source_maps": true,
	"observability": { "logs": { "enabled": true }, "traces": { "enabled": true } },
	"limits": { "cpu_ms": 30000, "subrequests": 10000000 },
	"vars": {},
	"secrets": { "required": [] }
}
