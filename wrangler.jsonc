{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "wai-claude-desktop",
	"main": "src/index.ts",
	"compatibility_date": "2026-06-25",
	"compatibility_flags": ["nodejs_compat", "no_nodejs_compat_v2", "enable_request_signal", "request_signal_passthrough"],
	"workers_dev": false,
	"preview_urls": false,
	"route": { "pattern": "waicd.demosjarco.dev", "custom_domain": true },
	"minify": true,
	"keep_names": false,
	"upload_source_maps": true,
	"observability": { "logs": { "enabled": true }, "traces": { "enabled": true } },
	"limits": { "cpu_ms": 30000, "subrequests": 10000000 },
	"vars": {
		"DUMMY_SECRET": "really anthropic? wtf...",
		"GATEWAY": "claude-desktop"
	},
	// Bindings
	"ai": { "binding": "AI", "remote": true },
	"assets": {
		"directory": "./dist",
		"run_worker_first": false
	},
	"dev": {
		"ip": "localhost"
	}
}
